# -----------------------------------------------------------------------------
PROJECT_NAME="InterviewX AI"
API_V1_STR="/api/v1"

# -----------------------------------------------------------------------------
# Backend Config
# -----------------------------------------------------------------------------
# CORS Origins (JSON list of strings)
